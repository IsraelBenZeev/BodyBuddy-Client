{
  "expo": {
    "name": "BodyBuddy",
    "slug": "BodyBuddy",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bodybuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#14161A"
      },
      "package": "com.ibz1330.bodybuddy",
      "versionCode": 17,
      "privacyPolicy": "https://israelbenzeev.github.io/BodyBuddu-Privacy-Policy",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "bodybuddy-yn"
        }
      ],
      "./plugins/withAndroidRTL",
      "./plugins/withIosRTL",
      [
        "expo-localization",
        {
          "supportsRTL": true,
          "forcesRTL": true
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-placeholder.png",
          "backgroundColor": "#0d1117",
          "dark": {
            "backgroundColor": "#0d1117"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "react-native-edge-to-edge",
      "expo-video"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c93f8a66-2ee4-41ea-b38e-66adf5f00f45"
      }
    }
  }
}
